# Wallet Buddhi Portal — environment example
# Copy to .env and fill in. Never commit .env.

# --- On-chain ---
# Helius API key (https://helius.xyz) — primary on-chain data source
HELIUS_API_KEY=

# Solana network: mainnet-beta | devnet
SOLANA_NETWORK=mainnet-beta

# --- Socials (Phase F) ---
TWITTER_API_KEY=
TGSTAT_API_KEY=
TELEGRAM_BOT_TOKEN=

# --- LLM (Phase G) ---
# Ollama host for local model experimentation
OLLAMA_HOST=http://localhost:11434
# Cloud fallback
ANTHROPIC_API_KEY=

# --- Storage (Phase B+) ---
DATABASE_URL=
REDIS_URL=
